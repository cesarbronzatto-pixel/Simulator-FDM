{
  "entities": {
    "history": {
      "title": "History Entry",
      "description": "Store record of a completed roleplay session for training assessment.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique ID of the user who completed the session." },
        "userEmail": { "type": "string", "description": "Email address of the user." },
        "userName": { "type": "string", "description": "Display name of the user." },
        "date": { "type": "string", "format": "date-time", "description": "ISO timestamp of when the session was saved." },
        "persona": { "type": "string", "description": "Name of the persona the user interacted with." },
        "score": { "type": "number", "description": "Final score calculated for the session (0-100)." },
        "chatHistory": {
          "type": "array",
          "description": "The full list of messages exchanged during the session.",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model", "system"] },
              "content": { "type": "string" }
            }
          }
        },
        "report": {
          "type": "object",
          "description": "Detailed analysis report generated by the AI.",
          "properties": {
            "sessao": {
              "type": "object",
              "properties": {
                "persona": { "type": "string" },
                "dificuldade": { "type": "string" },
                "score_final": { "type": "number" }
              }
            },
            "checkpoints": {
              "type": "object",
              "properties": {
                "pitch_claro_e_objetivo": { "type": "boolean" },
                "tratou_objecoes_com_seguranca": { "type": "boolean" },
                "conectou_valor_a_dor": { "type": "boolean" },
                "conduziu_para_fechamento": { "type": "boolean" }
              }
            },
            "analise_comercial": {
              "type": "object",
              "properties": {
                "pontos_fortes": { "type": "string" },
                "pontos_a_melhorar": { "type": "string" },
                "veredito": { "type": "string" }
              }
            }
          }
        }
      },
      "required": ["userId", "userEmail", "userName", "date", "persona", "score", "report"]
    }
  },
  "firestore": {
    "history": {
      "path": "/history/{historyId}",
      "schema": "history",
      "description": "Collection of all roleplay results for training evaluation and management reporting."
    }
  }
}
