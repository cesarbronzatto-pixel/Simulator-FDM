rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'caio.vidal@xertica.com' || 
        request.auth.token.email == 'cesar.bronzatto@xertica.com' ||
        request.auth.token.email == 'renata.perina@xertica.com' ||
        request.auth.token.email == 'gustavo.paula@xertica.com' ||
        request.auth.token.email == 'desyre.guerrero@xertica.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidHistory(data) {
      let requiredFields = ['userId', 'userEmail', 'userName', 'date', 'persona', 'score', 'report'];
      let optionalFields = ['chatHistory'];
      let allFields = requiredFields.concat(optionalFields);
      
      return data.keys().hasAll(requiredFields) && 
             data.keys().hasOnly(allFields) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() <= 256 &&
             data.userName is string && data.userName.size() <= 256 &&
             data.date is string && data.date.size() <= 64 &&
             data.persona is string && data.persona.size() <= 128 &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.report is map &&
             (!data.keys().hasAny(['chatHistory']) || (data.chatHistory is list && data.chatHistory.size() <= 200));
    }

    match /history/{historyId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isValidId(historyId) && (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid));
      allow create: if isValidId(historyId) && isSignedIn() && isValidHistory(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
